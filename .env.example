# =============================================================================
# HOW TO USE THIS FILE
# =============================================================================
# Copy this file to `.env` when running docker-compose.yml.
# This root `.env` controls Docker Compose infrastructure mode, image runtime
# URLs, shared secrets, and production service credentials.
#
# Package-level `.env.example` files are for manual service runs and local
# package development. Docker Compose can read those too, but this root file is
# where you choose bundled vs external Postgres/Redis.

# --- COMPOSE MODE ---
# Default mode: docker-compose.yml starts bundled Postgres and Redis.
COMPOSE_PROFILES=bundled-postgres,bundled-redis
#
# Common modes:
# - Docker Postgres + Docker Redis: COMPOSE_PROFILES=bundled-postgres,bundled-redis
# - Docker Postgres + hosted Redis: COMPOSE_PROFILES=bundled-postgres and set REDIS_URL
# - External Postgres + Docker Redis: COMPOSE_PROFILES=bundled-redis and set DATABASE_URL
# - External Postgres + hosted Redis: COMPOSE_PROFILES=external-infra and set DATABASE_URL + REDIS_URL

# --- SERVER PATHS & DB ---
# Used by the bundled Postgres service when `bundled-postgres` is enabled.
POSTGRES_USER=fakegaming
POSTGRES_PASSWORD=CHANGE_THIS_POSTGRES_PASSWORD
POSTGRES_DB=fakegaming
# Optional external DB override. Leave unset when using bundled Postgres.
# DATABASE_URL=postgres://fakegaming:password@postgres-host:5432/fakegaming
# Host paths for persistent Docker volumes.
POSTGRES_DATA_PATH=/data/fakegaming/postgres
BOT_DATA_PATH=/data/fakegaming/bot

# --- REDIS ---
# Shared Redis is required for dashboard refresh sessions and guild permission caches.
# Use redis://redis:6379 with the bundled Docker service, or set this to hosted Redis.
REDIS_URL=redis://redis:6379
# Only used when running the bundled Redis service (`bundled-redis` profile).
REDIS_DATA_PATH=/data/fakegaming/redis

# --- PRODUCTION DOMAINS ---
# Public URLs used by OAuth callbacks, CORS, generated links, and dashboard/API routing.
PRODUCTION_DASHBOARD_URL=https://fakegaming.eu
PRODUCTION_API_URL=https://api.fakegaming.eu

# --- PUBLIC LEGAL / PRIVACY DISPLAY ---
# Used by the dashboard privacy page. NEXT_PUBLIC_PRIVACY_CONTACT can be a URL,
# Discord handle, GitHub issue link, or email; it does not have to be an email.
NEXT_PUBLIC_PUBLIC_INSTANCE=false
NEXT_PUBLIC_INSTANCE_NAME=Fakegaming Bot
NEXT_PUBLIC_INSTANCE_DOMAIN=fakegaming.eu
NEXT_PUBLIC_OPERATOR_NAME=Zeffuro
# NEXT_PUBLIC_OPERATOR_COUNTRY=Netherlands
# NEXT_PUBLIC_STORAGE_COUNTRIES=Germany,Netherlands
NEXT_PUBLIC_PRIVACY_CONTACT=https://yourdomain.com/contact

# --- DISCORD APP CREDENTIALS ---
# Discord application credentials used by dashboard OAuth and API Discord helpers.
DISCORD_CLIENT_ID=1234567891234567890
DISCORD_CLIENT_SECRET=????????????????????????????????
DISCORD_BOT_TOKEN=??????????????????????????.??????.??????????-?????????-?????????????????

# --- BOT-SPECIFIC DISCORD CONFIGS ---
# Bot command registration target. The client ID is usually the same application as above.
BOT_DISCORD_CLIENT_ID=1234567891234567890
BOT_DISCORD_GUILD_ID=123456789123456789
# auto skips Discord command checks when the last successful manifest hash matches.
# Use always for local debugging or force redeploys, never for emergency Discord API avoidance.
COMMAND_DEPLOY_MODE=auto
COMMAND_DEPLOY_SCOPE=global
# COMMAND_DEPLOY_SCOPE=guild uses BOT_DISCORD_GUILD_ID unless COMMAND_DEPLOY_GUILD_ID is set.
# COMMAND_DEPLOY_GUILD_ID=123456789123456789

# --- PATCH NOTE HISTORY STORAGE ---
# Bounds stored patch-note history before any dashboard hub loads it.
PATCH_NOTE_HISTORY_RETENTION_DAYS=365
PATCH_NOTE_HISTORY_MAX_PER_GAME=50
PATCH_NOTE_HISTORY_MAX_BODY_BYTES=120000

# --- SHARED SECRETS ---
# DASHBOARD_ADMINS is a comma-separated list of Discord user IDs.
# JWT_SECRET and SERVICE_API_TOKEN must be long random values and must match
# any package-level env files used for manual service runs.
DASHBOARD_ADMINS=123456789123456789
JWT_SECRET=???????????????????????????????????????????=
SERVICE_API_TOKEN=??????????????????????????????????????????=

# --- THIRD-PARTY API KEYS ---
# Optional integrations. Leave unused keys unset in real deployments if the
# corresponding feature is disabled.
TWITCH_CLIENT_ID=??????????????????????????????
TWITCH_CLIENT_SECRET=??????????????????????????????
TWITCH_TOKEN_ENC_KEY=???????????????????????????????
YOUTUBE_API_KEY=????????????????????????????????????????
# Optional. Steam news works without this, but app-name search can use it for
# the keyed StoreService app list before falling back to the public app list.
STEAM_WEB_API_KEY=????????????????????????????????
# Experimental/self-host-sensitive TikTok live support. Only set this if you
# operate your own instance and accept the provider tradeoffs.
# TIKTOK_COOKIE=msToken=???????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????=
RIOT_LEAGUE_API_KEY=RGAPI-????????-????-????-????-????????????
RIOT_TFT_API_KEY=RGAPI-????????-????-????-????-????????????
RIOT_DEV_API_KEY=RGAPI-????????-????-????-????-????????????
# Optional League recent-form command bounds. Match count defaults to 5 and
# is capped at 10. TTL defaults to 60 minutes.
RIOT_RECENT_FORM_MATCH_COUNT=5
RIOT_RECENT_FORM_TTL_MINUTES=60
OPENWEATHER_API_KEY=????????????????????????????????
