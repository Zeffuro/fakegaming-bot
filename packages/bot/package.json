{
  "name": "@zeffuro/fakegaming-bot",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "description": "",
  "author": "Zeffuro",
  "license": "AGPL-3.0-only",
  "scripts": {
    "prebuild": "tsx ../../scripts/generate-bot-manifest.ts && pnpm -C ../../packages/common build",
    "build": "pnpm --filter @zeffuro/fakegaming-common run build && tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "prod:dev": "cross-env NODE_ENV=production tsx src/index.ts",
    "start:dev": "cross-env NODE_ENV=development tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts --config ../../eslint.config.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "profile": "node --inspect-brk dist/index.js"
  },
  "dependencies": {
    "@zeffuro/fakegaming-common": "workspace:*",
    "axios": "^1.14.0",
    "canvas": "^3.2.3",
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "discord-api-types": "^0.38.44",
    "discord.js": "^14.26.2",
    "ms": "^2.1.3",
    "sqlite3": "^6.0.1",
    "sequelize": "^6.37.8",
    "twisted": "^1.72.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "pino-pretty": "^13.1.3"
  }
}