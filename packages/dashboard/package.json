{
  "name": "@zeffuro/fakegaming-bot-dashboard",
  "version": "1.0.0",
  "description": "Dashboard for Fakegaming.eu Bot.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "author": "Zeffuro",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "next build",
    "prebuild": "pnpm -w run gen:api-types",
    "prepare": "pnpm -w run gen:api-types",
    "start": "next start",
    "start:dev": "pnpm --filter @zeffuro/fakegaming-bot-api export:openapi && pnpm -w run gen:api-types && next dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint app components lib --ext .ts,.tsx --config ../../eslint.config.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@zeffuro/fakegaming-common": "workspace:*",
    "cross-env": "^10.1.0",
    "discord-api-types": "^0.38.45",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "pino-pretty": "^13.1.3"
  }
}