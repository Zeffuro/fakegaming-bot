# =============================================================================
# HOW TO USE THIS FILE
# =============================================================================
# Use this file for manual service runs or package-level local development.
# Docker Compose production also reads it, but root .env controls bundled vs
# external infrastructure and can inject REDIS_URL.

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
PUBLIC_URL=http://localhost:3000

# =============================================================================
# PUBLIC LEGAL / PRIVACY DISPLAY
# =============================================================================
# Set NEXT_PUBLIC_PUBLIC_INSTANCE=true only for an official hosted/public instance.
# NEXT_PUBLIC_PRIVACY_CONTACT can be a URL, Discord handle, GitHub issue link, or email.
NEXT_PUBLIC_PUBLIC_INSTANCE=false
NEXT_PUBLIC_INSTANCE_NAME=Fakegaming Bot Dashboard
NEXT_PUBLIC_INSTANCE_DOMAIN=localhost:3000
NEXT_PUBLIC_OPERATOR_NAME=Fakegaming Bot operator
# NEXT_PUBLIC_OPERATOR_COUNTRY=Netherlands
# NEXT_PUBLIC_STORAGE_COUNTRIES=Germany,Netherlands
NEXT_PUBLIC_PRIVACY_CONTACT=Ask your instance operator

# =============================================================================
# LOGGING (pino)
# =============================================================================
# Server-side logs only (Next.js server components/API routes). Client logs are unaffected.
# Set log level: fatal|error|warn|info|debug|trace (defaults: production=info, development=debug)
# LOG_LEVEL=debug
# Enable pretty logs in development only (requires dev dependency pino-pretty in the monorepo)
# LOG_PRETTY=1
# Optional: choose pretty mode: 'short' (single-line) or 'expanded' (multi-line). Defaults to 'short'.
# LOG_PRETTY_MODE=expanded

# =============================================================================
# API CONNECTION
# =============================================================================
# URL of the Express API that the dashboard connects to (base should include /api)
API_URL=http://localhost:3001/api
# Must match API SERVICE_API_TOKEN for dashboard-admin proxy requests
SERVICE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# DISCORD OAUTH
# =============================================================================
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
DISCORD_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# DASHBOARD ADMINS
# =============================================================================
# Comma-separated list of Discord user IDs with admin access
DASHBOARD_ADMINS=123456789012345678,987654321098765432

# =============================================================================
# JWT & AUTHENTICATION
# =============================================================================
# MUST match the API's JWT configuration
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_AUDIENCE=fakegaming-dashboard
JWT_ISSUER=fakegaming

# =============================================================================
# REDIS SHARED CACHE
# =============================================================================
# Required when API and Dashboard run as separate processes/containers.
# The dashboard stores refresh sessions, Discord access tokens, profiles, and
# guild permissions here. Without Redis, login cookies may be issued but refresh
# and guild-scoped API authorization will not work reliably.
# Use a local Redis, a Docker Redis, or hosted Redis. API and Dashboard must
# point to the same instance.
REDIS_URL=redis://localhost:6379
