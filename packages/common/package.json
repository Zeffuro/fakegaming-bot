{
  "name": "@zeffuro/fakegaming-common",
  "version": "1.0.0",
  "description": "Common database models and utilities for FakeGaming projects.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "author": "Zeffuro",
  "license": "AGPL-3.0-only",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "import": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    },
    "./managers": {
      "import": "./dist/managers/index.js",
      "types": "./dist/managers/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./discord": {
      "import": "./dist/discord/index.js",
      "types": "./dist/discord/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./utils/cache": {
      "import": "./dist/utils/cacheManager.js",
      "types": "./dist/utils/cacheManager.d.ts"
    },
    "./auth": {
      "import": "./dist/discord/auth.js",
      "types": "./dist/discord/auth.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    },
    "./security": {
      "import": "./dist/security/index.js",
      "types": "./dist/security/index.d.ts"
    },
    "./manifest": {
      "import": "./dist/manifest/index.js",
      "types": "./dist/manifest/index.d.ts"
    },
    "./manifest/bot-manifest": {
      "import": "./dist/manifest/bot-manifest.js",
      "types": "./dist/manifest/bot-manifest.d.ts"
    },
    "./jobs": {
      "import": "./dist/jobs/index.js",
      "types": "./dist/jobs/index.d.ts"
    },
    "./patchnotes": {
      "import": "./dist/patchnotes/index.js",
      "types": "./dist/patchnotes/index.d.ts"
    },
    "./anime": {
      "import": "./dist/anime/index.js",
      "types": "./dist/anime/index.d.ts"
    },
    "./steam": {
      "import": "./dist/steam/index.js",
      "types": "./dist/steam/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "types": "./dist/api/index.d.ts"
    },
    "./quote-card": {
      "import": "./dist/quote-card/index.js",
      "types": "./dist/quote-card/index.d.ts"
    },
    "./profile-card": {
      "import": "./dist/profile-card/index.js",
      "types": "./dist/profile-card/index.d.ts"
    },
    "./api-types": {
      "import": "./types/empty.js",
      "types": "./types/api.d.ts"
    },
    "./api-helpers": {
      "import": "./types/empty.js",
      "types": "./types/api-helpers.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "models": [
        "dist/models/index.d.ts"
      ],
      "models/*": [
        "dist/models/*"
      ],
      "managers": [
        "dist/managers/index.d.ts"
      ],
      "managers/*": [
        "dist/managers/*"
      ],
      "core": [
        "dist/core/index.d.ts"
      ],
      "core/*": [
        "dist/core/*"
      ],
      "discord": [
        "dist/discord/index.d.ts"
      ],
      "discord/*": [
        "dist/discord/*"
      ],
      "utils": [
        "dist/utils/index.d.ts"
      ],
      "utils/*": [
        "dist/utils/*"
      ],
      "utils/cache": [
        "dist/utils/cacheManager.d.ts"
      ],
      "auth": [
        "dist/discord/auth.d.ts"
      ],
      "testing": [
        "dist/testing/index.d.ts"
      ],
      "testing/*": [
        "dist/testing/*"
      ],
      "security": [
        "dist/security/index.d.ts"
      ],
      "manifest": [
        "dist/manifest/index.d.ts"
      ],
      "manifest/bot-manifest": [
        "dist/manifest/bot-manifest.d.ts"
      ],
      "jobs": [
        "dist/jobs/index.d.ts"
      ],
      "patchnotes": [
        "dist/patchnotes/index.d.ts"
      ],
      "anime": [
        "dist/anime/index.d.ts"
      ],
      "steam": [
        "dist/steam/index.d.ts"
      ],
      "api": [
        "dist/api/index.d.ts"
      ],
      "quote-card": [
        "dist/quote-card/index.d.ts"
      ],
      "profile-card": [
        "dist/profile-card/index.d.ts"
      ],
      "api/*": [
        "dist/api/*"
      ],
      "api-types": [
        "types/api.d.ts"
      ],
      "api-helpers": [
        "types/api-helpers.d.ts"
      ]
    }
  },
  "scripts": {
    "prebuild": "tsx ../../scripts/generate-bot-manifest.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.d.ts --config ../../eslint.config.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "canvas": "^3.2.3",
    "cheerio": "^1.2.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "ioredis": "^5.11.1",
    "ms": "^2.1.3",
    "pino": "^10.3.1",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "sqlite3": "^6.0.1",
    "umzug": "^3.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.9"
  }
}
